@inherits LayoutComponentBase

<MudThemeProvider Theme="@_theme"/>
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout>

    <MudAppBar Elevation="2" Color="Color.Primary">

        <MudText Typo="Typo.h6" Class="ml-3">
            Счетоводен Калкулатор
        </MudText>

        <MudSpacer />

        <MudButton Href="/"
                   Color="Color.Inherit"
                   Variant="Variant.Text"
                   StartIcon="@Icons.Material.Filled.Receipt">
            ДДС
        </MudButton>

        <MudButton Href="/"
                   Color="Color.Inherit"
                   Variant="Variant.Text"
                   StartIcon="@Icons.Material.Filled.People">
            Заплата
        </MudButton>

        <MudButton Href="/"
                   Color="Color.Inherit"
                   Variant="Variant.Text"
                   StartIcon="@Icons.Material.Filled.AccountBalance">
            Корпоративен данък
        </MudButton>

        <MudButton Href="/"
                   Color="Color.Inherit"
                   Variant="Variant.Text"
                   StartIcon="@Icons.Material.Filled.Summarize">
            Дневник ДДС
        </MudButton>

    </MudAppBar>

    <MudMainContent>
        <MudToolBar />
        <MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="mt-4 pa-4">
            @Body
        </MudContainer>
    </MudMainContent>
</MudLayout>

@code{
    private MudTheme _theme = new MudTheme()
    {
        PaletteLight = new PaletteLight()
        {
           // Primary = "#1565C0",   // deep blue
            Secondary = "#546E7A",   // blue grey — replaces the red
            Tertiary = "#00796B",   // teal
            Success = "#2E7D32",   // dark green
            Warning = "#F57F17",   // amber
            Error = "#C62828",   // dark red
            Background = "#F5F5F5",  // light grey page background
            Surface = "#FFFFFF",   // white cards
        }
    };
}

